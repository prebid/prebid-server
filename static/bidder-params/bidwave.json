{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "BidWave Adapter Params",
  "description": "A schema which validates params accepted by the BidWave adapter",
  "type": "object",
  "properties": {
    "publisherId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
      "description": "Publisher ID"
    }
  },
  "required": [
    "publisherId"
  ]
}
